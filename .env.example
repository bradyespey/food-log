# FoodLog Environment Variables
# Keep real .env files on local disk only. Never commit .env to git.

# Add To Netlify And Check Contains Secret Values

## Lose It Session
LOSEIT_COOKIE=

## OpenAI
OPENAI_API_KEY=

# Add To Netlify And Uncheck Contains Secret Values

## FoodLog Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
