# Firebase (same project as web app — mirror of root VITE_FIREBASE_* values)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Allowed users (must match root VITE_ALLOWED_EMAILS)
EXPO_PUBLIC_ALLOWED_EMAILS=

# Google OAuth — GCP Console → APIs & Services → Credentials
# iOS client: Application type iOS, bundle ID com.theespeys.foodlog (used for standalone builds)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Web client: "Web client (auto created by Google Service)" in GCP Credentials (used in Expo Go)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# API base URL — production Netlify functions (for local dev use LAN IP:8888)
EXPO_PUBLIC_API_BASE_URL=https://foodlog.theespeys.com
